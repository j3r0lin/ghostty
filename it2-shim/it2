#!/usr/bin/env python3
"""
ghostty-it2: Ghostty shim for the it2 CLI interface used by Claude Code.

Maps it2 session commands to Ghostty AppleScript calls.
Uses Ghostty's native terminal IDs directly as session IDs — no mapping needed.
"""
import argparse
import io
import json
import os
import shutil
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

_LOG_FILE = Path.home() / ".local/state/ghostty/it2-trace.log"


def _trace(msg):
    """Append a timestamped line to the trace log (noop if log dir missing)."""
    try:
        _LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
        with _LOG_FILE.open("a") as f:
            f.write(f"[{datetime.now().strftime('%H:%M:%S.%f')[:-3]}] {msg}\n")
    except OSError:
        pass


def run_applescript(script):
    return subprocess.run(
        ["osascript", "-e", script],
        capture_output=True, text=True,
    )


def _self_session_id():
    """Extract terminal ID from ITERM_SESSION_ID environment variable."""
    raw = os.environ.get("ITERM_SESSION_ID", "")
    return raw.split(":", 1)[1] if ":" in raw else ""


def _applescript_target(session_id):
    """Return an AppleScript expression for the target terminal."""
    sid = session_id or _self_session_id()
    if sid:
        return f'first terminal whose id is "{sid}"'
    return 'focused terminal of selected tab of front window'


def _escape_applescript(text):
    """Escape a string for use inside an AppleScript double-quoted literal."""
    return text.replace("\\", "\\\\").replace('"', '\\"')


def _applescript_string_literal(text):
    """Return an AppleScript expression that evaluates to the given text.

    Single-line strings are returned as double-quoted literals.
    Multi-line strings use 'linefeed' concatenation.
    """
    parts = text.split("\n")
    escaped_parts = [p.replace("\\", "\\\\").replace('"', '\\"') for p in parts]
    if len(escaped_parts) == 1:
        return f'"{escaped_parts[0]}"'
    return ' & linefeed & '.join(f'"{p}"' for p in escaped_parts)


def _applescript_action_text(text):
    """Return a perform action string for the text: action.

    Handles newlines by returning a list of action strings.
    """
    parts = text.split("\n")
    escaped_parts = [p.replace("\\", "\\\\").replace('"', '\\"') for p in parts]
    return escaped_parts


def _friendly_error(stderr):
    """Return a user-friendly error message from AppleScript stderr, or None."""
    err = stderr.strip()
    if "(-1719)" in err or "(-1728)" in err:
        marker = 'whose id = "'
        if marker in err:
            start = err.index(marker) + len(marker)
            end = err.index('"', start)
            return f"session not found: {err[start:end]}\nUse 'it2 session list' to see available sessions."
        return "target terminal not found"
    return None


def _run_and_check(script):
    r = run_applescript(script)
    if r.returncode != 0:
        msg = _friendly_error(r.stderr) or f"applescript error: {r.stderr.strip()}"
        print(msg, file=sys.stderr)
        sys.exit(1)
    return r


